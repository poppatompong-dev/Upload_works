{
  "name": "nsm-practical-submission",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "LAN-based practical exam submission system for Nakhon Sawan Municipality PR assistant candidates.",
  "scripts": {
    "dev": "concurrently -k \"vite --host 0.0.0.0\" \"node --watch server/index.js\"",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "test": "node --test tests/*.test.js",
    "seed:roster": "node scripts/seed-roster.js",
    "export:manifest": "node scripts/export-manifest.js",
    "service:install": "node scripts/install-service.js",
    "service:uninstall": "node scripts/uninstall-service.js",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "@fastify/multipart": "10.0.0",
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "11.2.0",
    "fastify": "5.8.5",
    "ffmpeg-static": "5.3.0",
    "ffprobe-static": "3.1.0",
    "file-type": "22.0.1",
    "lucide-react": "1.14.0",
    "mime-types": "3.0.2",
    "node-windows": "1.0.0-beta.8",
    "qrcode": "1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  }
}
